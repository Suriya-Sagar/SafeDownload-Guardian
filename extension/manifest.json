{
  "manifest_version": 3,
  "name": "File Security Guard",
  "version": "1.0.0",
  "description": "Protects your system by analyzing downloads before they reach your disk",
  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "webRequest"
  ],
  "host_permissions": [
    "http://*/",
    "https://*/",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://0.0.0.0:8000/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "http://0.0.0.0:5000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "192": "icons/icon192.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "192": "icons/icon192.png"
  }
}